          }
        }
      ]
    },
    {
      "name": "Library",
      "item": [
        {
          "name": "Create book with author (cross-resource)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"author\": {\n    \"firstName\": \"Frank\",\n    \"lastName\": \"Herbert\",\n    \"profile\": {\n      \"biography\": \"Author of Dune.\",\n      \"website\": \"https://example.com\"\n    }\n  },\n  \"book\": {\n    \"title\": \"Dune\",\n    \"description\": \"Epic science fiction novel.\",\n    \"publicationYear\": 1965,\n    \"publisherId\": 1,\n    \"authorIds\": [],\n    \"profile\": {\n      \"genre\": \"Science Fiction\",\n      \"pages\": 412,\n      \"language\": \"English\"\n    }\n  }\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/library/book-with-author",
              "host": ["{{baseUrl}}"],
              "path": ["api", "library", "book-with-author"]
            }
          }
        }
      ]
    }
  ]
}
